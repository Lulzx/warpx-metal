+
 using namespace amrex;
 using ablastr::utils::SignalHandling;
 
@@ -107,6 +117,91 @@ namespace
             }
         }
     }
+
+    constexpr double default_max_mem_fraction = 0.70;
+
+    double readMaxMemFraction ()
+    {
+        const char* value = std::getenv("WARPX_MAX_MEM_FRACTION");
+        if (value == nullptr || value[0] == '\0') {
+            return default_max_mem_fraction;
+        }
+
+        errno = 0;
+        char* end = nullptr;
+        double parsed = std::strtod(value, &end);
+        if (errno != 0 || end == value || parsed <= 0.0 || parsed > 1.0) {
+            return default_max_mem_fraction;
+        }
+        return parsed;
+    }
+
+#ifdef __APPLE__
+    bool sampleSystemMemoryBytes (std::uint64_t& used_bytes, std::uint64_t& physical_bytes)
+    {
+        physical_bytes = 0;
+        std::size_t physical_size = sizeof(physical_bytes);
+        if (sysctlbyname("hw.memsize", &physical_bytes, &physical_size, nullptr, 0) != 0 ||
+            physical_bytes == 0)
+        {
+            return false;
+        }
+
+        vm_size_t page_size = 0;
+        if (host_page_size(mach_host_self(), &page_size) != KERN_SUCCESS || page_size == 0) {
+            return false;
+        }
+
+        vm_statistics64_data_t stats {};
+        mach_msg_type_number_t count = HOST_VM_INFO64_COUNT;
+        if (host_statistics64(mach_host_self(), HOST_VM_INFO64,
+                              reinterpret_cast<host_info64_t>(&stats), &count) != KERN_SUCCESS)
+        {
+            return false;
+        }
+
+        const auto free_bytes = static_cast<std::uint64_t>(stats.free_count) *
+            static_cast<std::uint64_t>(page_size);
+        used_bytes = physical_bytes > free_bytes ? physical_bytes - free_bytes : 0;
+        return true;
+    }
+#else
+    bool sampleSystemMemoryBytes (std::uint64_t& used_bytes, std::uint64_t& physical_bytes)
+    {
+        used_bytes = 0;
+        physical_bytes = 0;
+        return false;
+    }
+#endif
+
+    void CheckSystemMemoryPressure ()
+    {
+        std::uint64_t used_bytes = 0;
+        std::uint64_t physical_bytes = 0;
+        if (!sampleSystemMemoryBytes(used_bytes, physical_bytes)) {
+            return;
+        }
+
+        const double max_fraction = readMaxMemFraction();
+        const long double threshold_bytes =
+            static_cast<long double>(physical_bytes) * max_fraction;
+        if (static_cast<long double>(used_bytes) < threshold_bytes) {
+            return;
+        }
+
+        constexpr long double gib = 1024.0L * 1024.0L * 1024.0L;
+        std::ostringstream msg;
+        msg << std::fixed << std::setprecision(1)
+            << "WarpX: system memory pressure exceeded "
+            << static_cast<int>(max_fraction * 100.0 + 0.5)
+            << "% of physical RAM (used "
+            << static_cast<long double>(used_bytes) / gib
+            << " GiB / "
+            << static_cast<long double>(physical_bytes) / gib
+            << " GiB) \u2014 deck too large for this machine; reduce resolution/particles "
+               "or raise WARPX_MAX_MEM_FRACTION at your own risk.";
+        amrex::Abort(msg.str());
+    }
 }
 
