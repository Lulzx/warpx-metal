diff --git a/Source/main.cpp b/Source/main.cpp
--- a/Source/main.cpp
+++ b/Source/main.cpp
@@ -13,7 +13,129 @@
 #include <ablastr/profiler/ProfilerWrapper.H>
 #include <ablastr/utils/timer/Timer.H>
 
+#include <AMReX.H>
 #include <AMReX_Print.H>
+
+#include <algorithm>
+#include <cerrno>
+#include <cmath>
+#include <cstdint>
+#include <cstdlib>
+#include <iomanip>
+#include <sstream>
+
+#ifdef __APPLE__
+#include <mach/mach.h>
+#include <sys/sysctl.h>
+#endif
+
+namespace
+{
+    constexpr double default_max_mem_fraction = 0.70;
+
+    double readMaxMemFraction ()
+    {
+        const char* value = std::getenv("WARPX_MAX_MEM_FRACTION");
+        if (value == nullptr || value[0] == '\0') {
+            return default_max_mem_fraction;
+        }
+
+        errno = 0;
+        char* end = nullptr;
+        double parsed = std::strtod(value, &end);
+        if (errno != 0 || end == value || *end != '\0' ||
+            !std::isfinite(parsed) || parsed <= 0.0 || parsed > 1.0)
+        {
+            return default_max_mem_fraction;
+        }
+        return parsed;
+    }
+
+#ifdef __APPLE__
+    void AbortStartupMemorySamplingFailure ()
+    {
+        amrex::Abort(
+            "WarpX: startup macOS system memory pressure guard could not "
+            "sample VM statistics; refusing to run without the crashguard on "
+            "Apple hosts.");
+    }
+
+    void CheckStartupSystemMemoryPressure ()
+    {
+        std::uint64_t physical_bytes = 0;
+        std::size_t physical_size = sizeof(physical_bytes);
+        if (sysctlbyname("hw.memsize", &physical_bytes, &physical_size, nullptr, 0) != 0 ||
+            physical_bytes == 0)
+        {
+            AbortStartupMemorySamplingFailure();
+            return;
+        }
+
+        vm_size_t page_size = 0;
+        if (host_page_size(mach_host_self(), &page_size) != KERN_SUCCESS || page_size == 0) {
+            AbortStartupMemorySamplingFailure();
+            return;
+        }
+
+        vm_statistics64_data_t stats {};
+        mach_msg_type_number_t count = HOST_VM_INFO64_COUNT;
+        if (host_statistics64(mach_host_self(), HOST_VM_INFO64,
+                              reinterpret_cast<host_info64_t>(&stats), &count) != KERN_SUCCESS)
+        {
+            AbortStartupMemorySamplingFailure();
+            return;
+        }
+
+        int pressure_level = 0;
+        bool has_pressure_level = false;
+        std::size_t pressure_size = sizeof(pressure_level);
+        has_pressure_level = sysctlbyname("kern.memorystatus_vm_pressure_level",
+                                          &pressure_level, &pressure_size, nullptr, 0) == 0;
+
+        const auto free_pages = static_cast<std::uint64_t>(stats.free_count);
+        const auto file_backed_pages = static_cast<std::uint64_t>(stats.external_page_count);
+        const auto purgeable_pages = static_cast<std::uint64_t>(stats.purgeable_count);
+        const auto extra_purgeable_pages = purgeable_pages > file_backed_pages ?
+            purgeable_pages - file_backed_pages : 0;
+        const auto available_pages = free_pages + file_backed_pages + extra_purgeable_pages;
+        const auto available_bytes = std::min(
+            physical_bytes,
+            available_pages * static_cast<std::uint64_t>(page_size));
+        const auto used_bytes = physical_bytes > available_bytes ?
+            physical_bytes - available_bytes : 0;
+
+        const double max_fraction = readMaxMemFraction();
+        const auto over_fraction =
+            static_cast<long double>(used_bytes) >=
+            static_cast<long double>(physical_bytes) * max_fraction;
+        const auto abnormal_pressure = has_pressure_level && pressure_level > 1;
+        if (!over_fraction && !abnormal_pressure) {
+            return;
+        }
+
+        constexpr long double gib = 1024.0L * 1024.0L * 1024.0L;
+        std::ostringstream msg;
+        msg << std::fixed << std::setprecision(1)
+            << "WarpX: system memory pressure exceeded "
+            << static_cast<int>(max_fraction * 100.0 + 0.5)
+            << "% of physical RAM (startup guard; used "
+            << static_cast<long double>(used_bytes) / gib
+            << " GiB / "
+            << static_cast<long double>(physical_bytes) / gib
+            << " GiB, available "
+            << static_cast<long double>(available_bytes) / gib
+            << " GiB";
+        if (has_pressure_level) {
+            msg << ", pressure level " << pressure_level;
+        }
+        msg << ") - deck too large for this machine; reduce resolution/particles "
+               "or raise WARPX_MAX_MEM_FRACTION at your own risk.";
+        amrex::Abort(msg.str());
+    }
+#else
+    void CheckStartupSystemMemoryPressure () {}
+#endif
+}
 
