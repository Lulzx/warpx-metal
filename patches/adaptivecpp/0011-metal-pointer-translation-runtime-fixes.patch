+  auto emitFetch64 = [&](const std::string& type) -> bool {
+    if (CI->arg_size() < 3 || CI->getType()->isVoidTy()) {
+      return false;
+    }
+
+    auto emitLowWordFetch64 = [&](const std::string& op) -> bool {
+      const bool isSigned = type == "long";
+      os << indent(level) << "{\n";
+      os << indent(level + 1) << "auto ptr = " << emitExprArg(1) << ";\n";
+      os << indent(level + 1) << type << " val = " << emitExprArg(2) << ";\n";
+      if (isSigned) {
+        os << indent(level + 1) << "uint old_lo = (uint)atomic_fetch_" << op
+           << "_explicit(__atomic_pointer_cast<int>(ptr), (int)val, memory_order_relaxed);\n";
+      } else {
+        os << indent(level + 1) << "uint old_lo = atomic_fetch_" << op
+           << "_explicit(__atomic_pointer_cast<uint>(ptr), (uint)val, memory_order_relaxed);\n";
+      }
+      os << indent(level + 1) << name << " = (" << type << ")old_lo;\n";
+      os << indent(level) << "}\n";
+      return true;
+    };
+
+    if (funcName->find("atomic_fetch_add_explicit") != std::string::npos) {
+      return emitLowWordFetch64("add");
+    } else if (funcName->find("atomic_fetch_sub_explicit") != std::string::npos) {
+      return emitLowWordFetch64("sub");
+    }
+
+    std::string expr;
+    if (funcName->find("atomic_fetch_and_explicit") != std::string::npos) {
+      expr = "old & val";
+    } else if (funcName->find("atomic_fetch_or_explicit") != std::string::npos) {
+      expr = "old | val";
+    } else if (funcName->find("atomic_fetch_xor_explicit") != std::string::npos) {
+      expr = "old ^ val";
+    } else if (funcName->find("atomic_fetch_min_explicit") != std::string::npos) {
+      expr = "(old < val) ? old : val";
+    } else if (funcName->find("atomic_fetch_max_explicit") != std::string::npos) {
+      expr = "(old > val) ? old : val";
+    } else {
+      return false;
+    }
+
+    os << indent(level) << "{\n";
+    os << indent(level + 1) << "auto ptr = __pointer_cast<" << type
+       << ">(" << emitExprArg(1) << ");\n";
+    os << indent(level + 1) << type << " old = *ptr;\n";
+    os << indent(level + 1) << type << " val = " << emitExprArg(2) << ";\n";
+    os << indent(level + 1) << "*ptr = " << expr << ";\n";
+    os << indent(level + 1) << name << " = old;\n";
+    os << indent(level) << "}\n";
+    return true;
+  };
+
+  if (CI->getType()->isIntegerTy(64) &&
+      funcName->find("atomic_fetch_") != std::string::npos &&
+      funcName->find("_explicit") != std::string::npos &&
+      emitFetch64("ulong")) {
+    return true;
+  }
+
+  auto emitAtomic64Inline = [&]() -> bool {
+    auto hasSuffix = [](const std::string& value, const std::string& suffix) {
+      return value.size() >= suffix.size() &&
+             value.compare(value.size() - suffix.size(), suffix.size(), suffix) == 0;
+    };
+
+    std::string type;
+    std::string suffix;
+    if (hasSuffix(ctx->name, "_i64")) {
+      type = "long";
+      suffix = "_i64";
+    } else if (hasSuffix(ctx->name, "_u64")) {
+      type = "ulong";
+      suffix = "_u64";
+    } else {
+      return false;
+    }
+
+    if (ctx->name.find("__acpp_sscp_metal_atomic_load" + suffix) == 0) {
+      if (CI->arg_size() < 2 || CI->getType()->isVoidTy()) {
+        return false;
+      }
+      os << indent(level) << name << " = *__pointer_cast<" << type << ">("
+         << emitExprArg(1) << ");\n";
+      return true;
+    }
+
+    if (ctx->name.find("__acpp_sscp_metal_atomic_store" + suffix) == 0) {
+      if (CI->arg_size() < 3) {
+        return false;
+      }
+      os << indent(level) << "*__pointer_cast<" << type << ">(" << emitExprArg(1)
+         << ") = " << emitExprArg(2) << ";\n";
+      return true;
+    }
+
+    if (ctx->name.find("__acpp_sscp_metal_atomic_exchange" + suffix) == 0) {
+      if (CI->arg_size() < 3 || CI->getType()->isVoidTy()) {
+        return false;
+      }
+      os << indent(level) << "{\n";
+      os << indent(level + 1) << "auto ptr = __pointer_cast<" << type
+         << ">(" << emitExprArg(1) << ");\n";
+      os << indent(level + 1) << type << " old = *ptr;\n";
+      os << indent(level + 1) << "*ptr = " << emitExprArg(2) << ";\n";
+      os << indent(level + 1) << name << " = old;\n";
+      os << indent(level) << "}\n";
+      return true;
+    }
+
+    if (ctx->name.find("__acpp_sscp_metal_atomic_cmpxchg" + suffix) == 0) {
+      if (CI->arg_size() < 4 || CI->getType()->isVoidTy()) {
+        return false;
+      }
+      os << indent(level) << "{\n";
+      os << indent(level + 1) << "auto ptr = __pointer_cast<" << type
+         << ">(" << emitExprArg(1) << ");\n";
+      os << indent(level + 1) << "auto expected = __pointer_cast<" << type
+         << ">(" << emitExprArg(2) << ");\n";
+      os << indent(level + 1) << type << " old = *ptr;\n";
+      os << indent(level + 1) << "if (old == *expected) { *ptr = "
+         << emitExprArg(3) << "; " << name << " = true; } else { *expected = old; "
+         << name << " = false; }\n";
+      os << indent(level) << "}\n";
+      return true;
+    }
+
+    if (ctx->name.find("__acpp_sscp_metal_atomic_fetch" + suffix) == 0) {
+      return emitFetch64(type);
+    }
+
+    return false;
+  };
+
+  if (emitAtomic64Inline()) {
+    return true;
+  }
