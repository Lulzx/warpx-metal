+  HIPSYCL_SSCP_BUILTIN type __acpp_sscp_atomic_fetch_##op##_##type( \
+      __acpp_sscp_address_space as, __acpp_sscp_memory_order order, \
+      __acpp_sscp_memory_scope scope, type *ptr, type x) { \
+    type old = *ptr; *ptr = expr; return old; \
+  }
+
