+ACPP_METAL_FETCH_OP_64(u64, add, old + x)
+ACPP_METAL_FETCH_OP_64(i64, sub, old - x)
+ACPP_METAL_FETCH_OP_64(u64, sub, old - x)
+ACPP_METAL_FETCH_OP_64(i64, and, old & x)
+ACPP_METAL_FETCH_OP_64(u64, and, old & x)
+ACPP_METAL_FETCH_OP_64(i64, or, old | x)
+ACPP_METAL_FETCH_OP_64(u64, or, old | x)
+ACPP_METAL_FETCH_OP_64(i64, xor, old ^ x)
+ACPP_METAL_FETCH_OP_64(u64, xor, old ^ x)
+ACPP_METAL_FETCH_OP_64(i64, min, (old < x) ? old : x)
+ACPP_METAL_FETCH_OP_64(u64, min, (old < x) ? old : x)
+ACPP_METAL_FETCH_OP_64(i64, max, (old > x) ? old : x)
+ACPP_METAL_FETCH_OP_64(u64, max, (old > x) ? old : x)
