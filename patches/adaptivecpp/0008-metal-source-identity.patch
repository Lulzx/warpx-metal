+result build_metal_library_from_binary(MTL::Library*& library,
+                                       MTL::Device* device,
+                                       const std::string& metallib) {
+  if (!device) {
+    return make_error(__acpp_here(),
+                      error_info{"metal_code_object: Device is null"});
+  }
+
+  if (metallib.empty()) {
+    return make_error(__acpp_here(),
+                      error_info{"metal_code_object: Metal library binary is empty"});
+  }
+
+  void* data = std::malloc(metallib.size());
+  if (!data) {
+    return make_error(__acpp_here(),
+                      error_info{"metal_code_object: Could not allocate Metal library buffer"});
+  }
+  std::memcpy(data, metallib.data(), metallib.size());
+
+  dispatch_data_t dispatch_data = dispatch_data_create(
+      data, metallib.size(), dispatch_get_global_queue(QOS_CLASS_DEFAULT, 0),
+      DISPATCH_DATA_DESTRUCTOR_FREE);
+  if (!dispatch_data) {
+    std::free(data);
+    return make_error(__acpp_here(),
+                      error_info{"metal_code_object: Could not create dispatch_data for Metal library"});
+  }
+
+  NS::Error* error = nullptr;
+  library = device->newLibrary(dispatch_data, &error);
+  dispatch_release(dispatch_data);
+
+  if (error || !library) {
+    return make_error(__acpp_here(),
+                      error_info{metal_error_message(
+                          "metal_code_object: Could not load cached Metal library",
+                          error)});
+  }
+
+  HIPSYCL_DEBUG_INFO << "metal_code_object: Loaded cached Metal library of size "
+                     << metallib.size() << std::endl;
+  return make_success();
+}
