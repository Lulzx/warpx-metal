+metal_allocator::get_pointer_translation_entries() const {
+  std::vector<pointer_translation_entry> entries;
+  std::lock_guard<std::mutex> lock{_mutex};
+  for (const auto& [host_ptr, block] : _ptr_to_block) {
+    if (!block.buffer) {
+      continue;
+    }
+    std::uint64_t host_addr = reinterpret_cast<std::uint64_t>(host_ptr);
+    std::uint64_t gpu_addr = static_cast<std::uint64_t>(block.buffer->gpuAddress());
+    if (block.alloc_type == usm_alloc_type::device) {
+      host_addr = gpu_addr;
+    }
+    entries.push_back(pointer_translation_entry{
+      host_addr,
+      gpu_addr,
+      static_cast<std::uint64_t>(block.buffer->length())
+    });
+  }
+  return entries;
