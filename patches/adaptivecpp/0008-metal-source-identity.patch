+result compile_metal_source_to_metallib(
+    const std::string &metal_source,
+    kernel_cache::code_object_id id_of_binary,
+    std::string &metallib) {
+  std::string cache_file = kernel_cache::get_persistent_cache_file(id_of_binary);
+  std::string source_path = cache_file + ".metal";
+  std::string air_path = cache_file + ".air";
+  std::string metallib_path = cache_file + ".metallib";
+
+  if (!common::filesystem::atomic_write(source_path, metal_source)) {
+    return make_error(__acpp_here(),
+                      error_info{"metal_code_object: Could not write temporary MSL source"});
+  }
+
+  result compile_result = run_metal_toolchain(source_path, air_path, metallib_path);
+  remove_if_present(source_path);
+  remove_if_present(air_path);
+  if (!compile_result.is_success()) {
+    remove_if_present(metallib_path);
+    return compile_result;
+  }
+
+  if (!read_binary_file(metallib_path, metallib)) {
+    remove_if_present(metallib_path);
+    return make_error(__acpp_here(),
+                      error_info{"metal_code_object: Could not read compiled Metal library"});
+  }
+
+  remove_if_present(metallib_path);
+  return make_success();
