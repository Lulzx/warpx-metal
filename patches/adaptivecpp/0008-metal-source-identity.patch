+result get_or_create_metal_pipeline_state(
+    MTL::Device* device, MTL::Library* library, MTL::Function* function,
+    std::string_view kernel_name, MTL::BinaryArchive* archive,
+    const std::string& archive_path,
+    NS::SharedPtr<MTL::ComputePipelineState>& pipeline_state) {
+  metal_pipeline_cache_key key{device, library, std::string{kernel_name}};
+
+  std::lock_guard<std::mutex> lock{get_metal_pipeline_cache_mutex()};
+  auto& cache = get_metal_pipeline_cache();
+  auto existing = cache.find(key);
+  if (existing != cache.end()) {
+    HIPSYCL_DEBUG_INFO << "[Metal] Compute pipeline cache hit for kernel "
+                       << kernel_name << std::endl;
+    pipeline_state = existing->second;
+    return make_success();
+  }
+
+  HIPSYCL_DEBUG_INFO << "[Metal] Compute pipeline cache miss for kernel "
+                     << kernel_name << std::endl;
+
+  metal_jit_guard::scoped_compile jit_compile{
+      "Metal compute pipeline compilation"};
+  result guard_result =
+      jit_compile.check("before Metal compute pipeline compilation");
+  if (!guard_result.is_success()) {
+    return guard_result;
+  }
+
+  std::string archive_error;
+  pipeline_state = new_pipeline_state_from_archive(
+      device, function, archive, archive_path, kernel_name,
+      true, archive_error);
+  guard_result = jit_compile.check("after Metal binary archive pipeline attempt");
+  if (!guard_result.is_success()) {
+    return guard_result;
+  }
+  if (!pipeline_state && archive && !archive_error.empty()) {
+    HIPSYCL_DEBUG_WARNING << archive_error << "; falling back to direct "
+                          << "pipeline compilation for kernel "
+                          << kernel_name << std::endl;
+  }
+
+  if (!pipeline_state) {
+    NS::Error* error = nullptr;
+    pipeline_state = NS::TransferPtr(
+        device->newComputePipelineState(function, &error));
+    guard_result =
+        jit_compile.check("after Metal direct pipeline compilation");
+    if (!guard_result.is_success()) {
+      return guard_result;
+    }
+    if (error || !pipeline_state) {
+      return make_error(
+          __acpp_here(),
+          error_info{metal_error_message(
+              "metal: Failed to create compute pipeline state", error)});
+    }
+  }
+
+  cache.emplace(std::move(key), pipeline_state);
+  return make_success();
+}
