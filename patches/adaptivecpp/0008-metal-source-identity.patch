+std::string metal_error_message(const std::string& prefix, NS::Error* error) {
+  std::string msg = prefix;
+  if (error && error->localizedDescription()) {
+    msg += ": ";
+    msg += error->localizedDescription()->utf8String();
+  }
+  return msg;
+}
+
+std::string shell_quote(const std::string& value) {
+  std::string result = "'";
+  for (char c : value) {
+    if (c == '\'')
+      result += "'\\''";
+    else
+      result += c;
+  }
+  result += "'";
+  return result;
+}
+
+bool read_binary_file(const std::string& path, std::string& out) {
+  std::ifstream file{path, std::ios::in | std::ios::binary | std::ios::ate};
+  if (!file.is_open())
+    return false;
+
+  std::streamsize file_size = file.tellg();
+  if (file_size < 0)
+    return false;
+
+  file.seekg(0, std::ios::beg);
+  out.resize(static_cast<std::size_t>(file_size));
+  if (file_size == 0)
+    return true;
+  return static_cast<bool>(file.read(out.data(), file_size));
+}
+
+void remove_if_present(const std::string& path) {
+  std::remove(path.c_str());
+}
+
+result run_metal_toolchain(const std::string& source_path,
+                           const std::string& air_path,
+                           const std::string& metallib_path) {
+  std::string command =
+      "xcrun -sdk macosx metal -std=metal4.0 -Osize -c " +
+      shell_quote(source_path) + " -o " + shell_quote(air_path) +
+      " && xcrun -sdk macosx metallib " + shell_quote(air_path) +
+      " -o " + shell_quote(metallib_path);
+
+  int status = std::system(command.c_str());
+  if (status != 0) {
+    std::ostringstream msg;
+    msg << "metal_code_object: Offline Metal library compilation failed"
+        << " with status " << status
+        << "; command=" << command;
+    return make_error(__acpp_here(), error_info{msg.str()});
+  }
+  return make_success();
+}
+
+std::string make_metal_binary_archive_path(MTL::Device* device) {
+  std::ostringstream archive_name;
+  archive_name << "metal-pipeline-";
+  if (device) {
+    archive_name << std::hex << device->registryID();
+  } else {
+    archive_name << "no-device";
+  }
+  archive_name << ".binarchive";
+
+  return common::filesystem::join_path(
+      common::filesystem::persistent_storage::get().get_jit_cache_dir(),
+      archive_name.str());
+}
+
+MTL::BinaryArchive*
+open_metal_binary_archive(MTL::Device* device, const std::string& path) {
+  if (!device || path.empty()) {
+    return nullptr;
+  }
+
+  const char* enable_archive = std::getenv("ACPP_METAL_ENABLE_BINARY_ARCHIVE");
+  if (!enable_archive || std::string{enable_archive} != "1") {
+    return nullptr;
+  }
+
+  NS::Error* error = nullptr;
+  NS::SharedPtr<MTL::BinaryArchiveDescriptor> descriptor =
+      NS::TransferPtr(MTL::BinaryArchiveDescriptor::alloc()->init());
+  std::ifstream existing_archive{path, std::ios::binary};
+  if (existing_archive.good()) {
+    NS::String* path_string =
+        NS::String::string(path.c_str(), NS::UTF8StringEncoding);
+    NS::URL* archive_url = NS::URL::fileURLWithPath(path_string);
+    descriptor->setUrl(archive_url);
+  }
+
+  MTL::BinaryArchive* archive =
+      device->newBinaryArchive(descriptor.get(), &error);
+  if (error || !archive) {
+    HIPSYCL_DEBUG_WARNING
+        << "metal_code_object: Could not open Metal binary archive at "
+        << path;
+    if (error && error->localizedDescription()) {
+      HIPSYCL_DEBUG_WARNING
+          << ": " << error->localizedDescription()->utf8String();
+    }
+    HIPSYCL_DEBUG_WARNING << std::endl;
+    return nullptr;
+  }
+
+  HIPSYCL_DEBUG_INFO << "metal_code_object: Opened Metal binary archive "
+                     << path << std::endl;
+  return archive;
+}
