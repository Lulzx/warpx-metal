+    long raw_addr,
+    device __acpp_sscp_metal_pointer_translation_miss& miss_flag) {
+  if (raw_addr == 0) {
+    return raw_addr;
+  }
+  ulong addr = (ulong)raw_addr;
+  if (__acpp_sscp_metal_pointer_translation.count > __acpp_sscp_metal_pointer_translation.capacity) {
+    __acpp_metal_pointer_translation_fail(miss_flag, 4u, addr);
+    return 0;
+  }
+  for (uint i = 0; i < __acpp_sscp_metal_pointer_translation.count; ++i) {
+    __acpp_sscp_metal_pointer_translation_entry entry = __acpp_sscp_metal_pointer_translation.entries[i];
+    if (addr >= entry.host_base && addr < entry.host_base + entry.length) {
+      return (long)(entry.gpu_base + (addr - entry.host_base));
+    }
+  }
