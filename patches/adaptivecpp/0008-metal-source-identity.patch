+  table.count = static_cast<std::uint32_t>(
+    entries.size());
+  for (std::uint32_t i = 0; i < table.count; ++i) {
+    table.entries[i] = metal_pointer_translation_entry{
+      entries[i].host_base,
+      entries[i].gpu_base,
+      entries[i].length
+    };
+  }
+  return true;
+}
