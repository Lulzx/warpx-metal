+NS::SharedPtr<MTL::ComputePipelineState>
+new_pipeline_state_from_archive(MTL::Device* device,
+                                MTL::Function* function,
+                                MTL::BinaryArchive* archive,
+                                const std::string& archive_path,
+                                std::string_view kernel_name,
+                                bool allow_archive_population,
+                                std::string& error_msg) {
+  if (!archive || archive_path.empty()) {
+    return {};
+  }
+
+  NS::SharedPtr<MTL::ComputePipelineDescriptor> descriptor =
+      NS::TransferPtr(MTL::ComputePipelineDescriptor::alloc()->init());
+  descriptor->setComputeFunction(function);
+  NS::Array* archive_array =
+      NS::Array::array(reinterpret_cast<const NS::Object*>(archive));
+  descriptor->setBinaryArchives(archive_array);
+
+  NS::Error* error = nullptr;
+  NS::SharedPtr<MTL::ComputePipelineState> pipeline_state =
+      NS::TransferPtr(device->newComputePipelineState(
+          descriptor.get(), MTL::PipelineOptionFailOnBinaryArchiveMiss,
+          nullptr, &error));
+  if (pipeline_state && !error) {
+    HIPSYCL_DEBUG_INFO
+        << "[Metal] Persistent pipeline archive hit for kernel "
+        << kernel_name << " archive=" << archive_path << std::endl;
+    return pipeline_state;
+  }
+
+  if (!allow_archive_population) {
+    error_msg = metal_error_message(
+        "metal: Binary archive pipeline lookup failed", error);
+    return {};
+  }
+
+  HIPSYCL_DEBUG_INFO
+      << "[Metal] Persistent pipeline archive miss for kernel "
+      << kernel_name << " archive=" << archive_path << std::endl;
+
+  NS::Error* add_error = nullptr;
+  if (!archive->addComputePipelineFunctions(descriptor.get(), &add_error)) {
+    error_msg = metal_error_message(
+        "metal: Failed to populate binary archive", add_error);
+    return {};
+  }
+
+  NS::Error* serialize_error = nullptr;
+  if (!archive->serializeToURL(metal_archive_url(archive_path),
+                               &serialize_error)) {
+    HIPSYCL_DEBUG_WARNING
+        << metal_error_message(
+               "metal: Failed to serialize binary archive", serialize_error)
+        << " path=" << archive_path << std::endl;
+  }
+
+  error = nullptr;
+  pipeline_state = NS::TransferPtr(device->newComputePipelineState(
+      descriptor.get(), MTL::PipelineOptionFailOnBinaryArchiveMiss,
+      nullptr, &error));
+  if (pipeline_state && !error) {
+    HIPSYCL_DEBUG_INFO
+        << "[Metal] Populated persistent pipeline archive for kernel "
+        << kernel_name << " archive=" << archive_path << std::endl;
+    return pipeline_state;
+  }
+
+  error_msg =
+      metal_error_message("metal: Binary archive pipeline retry failed", error);
+  return {};
+}
