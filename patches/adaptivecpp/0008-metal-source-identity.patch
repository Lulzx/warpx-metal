@@ -0,0 +1,90 @@
+/*
+ * This file is part of AdaptiveCpp, an implementation of SYCL and C++ standard
+ * parallelism for CPUs and GPUs.
+ *
+ * AdaptiveCpp is released under the BSD 2-Clause "Simplified" License.
+ * See file LICENSE in the project root for full license details.
+ */
+// SPDX-License-Identifier: BSD-2-Clause
+#pragma once
+
+#include "hipSYCL/runtime/error.hpp"
+
+#include <cerrno>
+#include <chrono>
+#include <cstdlib>
+#include <cstring>
+#include <mutex>
+#include <thread>
+
+namespace hipsycl {
+namespace rt {
+namespace metal_jit_guard {
+
+inline constexpr std::size_t default_compile_yield_ms = 20;
+inline constexpr std::size_t default_postcheck_ms = 1000;
+
+inline std::size_t read_size_env(const char* name, std::size_t fallback) {
+  const char* value = std::getenv(name);
+  if (!value || value[0] == '\0') {
+    return fallback;
+  }
+
+  errno = 0;
+  char* end = nullptr;
+  unsigned long long parsed = std::strtoull(value, &end, 10);
+  if (errno != 0 || end == value) {
+    return fallback;
+  }
+  return static_cast<std::size_t>(parsed);
+}
+
+inline std::size_t compile_yield_ms() {
+  return read_size_env("ACPP_METAL_JIT_YIELD_MS", default_compile_yield_ms);
+}
+
+inline std::size_t postcheck_ms() {
+  return read_size_env("ACPP_METAL_JIT_POSTCHECK_MS",
+                       default_postcheck_ms);
+}
+
+inline std::mutex& compile_mutex() {
+  static std::mutex mutex;
+  return mutex;
+}
+
+class scoped_compile {
+public:
+  scoped_compile(const char* phase, std::size_t submitted_source_bytes = 0)
+      : _phase{phase}, _submitted_source_bytes{submitted_source_bytes},
+        _lock{compile_mutex()} {}
+
+  scoped_compile(const scoped_compile&) = delete;
+  scoped_compile& operator=(const scoped_compile&) = delete;
+
+  ~scoped_compile() {
+    const std::size_t yield_ms = compile_yield_ms();
+    if (yield_ms != 0) {
+      std::this_thread::sleep_for(std::chrono::milliseconds{yield_ms});
+    }
+  }
+
+  result check(const char* phase) const {
+    if (phase && std::strncmp(phase, "after ", 6) == 0) {
+      const std::size_t settle_ms = postcheck_ms();
+      if (settle_ms != 0) {
+        std::this_thread::sleep_for(std::chrono::milliseconds{settle_ms});
+      }
+    }
+    return make_success();
+  }
+
+private:
+  const char* _phase;
+  std::size_t _submitted_source_bytes;
+  std::unique_lock<std::mutex> _lock;
+};
+
+} // namespace metal_jit_guard
+} // namespace rt
+} // namespace hipsycl
