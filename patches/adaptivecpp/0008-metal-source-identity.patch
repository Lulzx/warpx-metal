+inline void __acpp_metal_pointer_translation_fail(
+    device __acpp_sscp_metal_pointer_translation_miss& miss_flag,
+    uint code,
+    ulong raw_addr) {
+  uint old = atomic_fetch_or_explicit(&miss_flag.code,
+                                      code, memory_order_relaxed);
+  if (old == 0) {
+    miss_flag.direction = code;
+    miss_flag.table_count = __acpp_sscp_metal_pointer_translation.count;
+    miss_flag.table_capacity = __acpp_sscp_metal_pointer_translation.capacity;
