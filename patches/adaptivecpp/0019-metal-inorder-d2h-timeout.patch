+      std::chrono::steady_clock::now() + std::chrono::milliseconds{timeout_ms};
   while (!_handle.event->waitUntilSignaledValue(_handle.value, 1000)) {
+    if (std::chrono::steady_clock::now() >= deadline) {
+      std::ostringstream message;
+      message << "metal_node_event: timed out after " << timeout_ms
+              << " ms waiting for shared-event value " << _handle.value
+              << "; current value is " << _handle.event->signaledValue();
