+std::chrono::milliseconds metal_command_buffer_timeout() {
+  constexpr unsigned long long default_timeout_ms = 120'000;
+  unsigned long long timeout_ms = default_timeout_ms;
+  if (const char* env = std::getenv("ACPP_METAL_COMMAND_TIMEOUT_MS")) {
+    char* end = nullptr;
+    const auto requested = std::strtoull(env, &end, 10);
+    if (end != env && *end == '\0' && requested > 0) {
+      timeout_ms = requested;
+    }
+  }
+  return std::chrono::milliseconds{timeout_ms};
+}
+
+const char* metal_command_buffer_status_name(MTL::CommandBufferStatus status) {
+  switch (status) {
+  case MTL::CommandBufferStatusNotEnqueued: return "not-enqueued";
+  case MTL::CommandBufferStatusEnqueued: return "enqueued";
+  case MTL::CommandBufferStatusCommitted: return "committed";
+  case MTL::CommandBufferStatusScheduled: return "scheduled";
+  case MTL::CommandBufferStatusCompleted: return "completed";
+  case MTL::CommandBufferStatusError: return "error";
+  }
+  return "unknown";
+}
+
+result wait_for_metal_command_buffer(MTL::CommandBuffer* command_buffer,
+                                     const char* operation) {
+  const auto deadline =
+      std::chrono::steady_clock::now() + metal_command_buffer_timeout();
+  auto status = command_buffer->status();
+  while (status != MTL::CommandBufferStatusCompleted &&
+         status != MTL::CommandBufferStatusError) {
+    if (std::chrono::steady_clock::now() >= deadline) {
+      std::ostringstream message;
+      message << "metal_queue: " << operation << " timed out after "
+              << metal_command_buffer_timeout().count()
+              << " ms; command buffer remained "
+              << metal_command_buffer_status_name(status);
+      return make_error(__acpp_here(), error_info{message.str()});
+    }
+    std::this_thread::sleep_for(std::chrono::milliseconds{1});
+    status = command_buffer->status();
+  }
+
+  if (status == MTL::CommandBufferStatusError) {
+    std::string message = "metal_queue: ";
+    message += operation;
+    message += " failed";
+    if (NS::Error* error = command_buffer->error()) {
+      if (error->localizedDescription()) {
+        message += ": ";
+        message += error->localizedDescription()->utf8String();
+      }
+    }
+    return make_error(__acpp_here(), error_info{message});
+  }
+
+  return make_success();
+}
