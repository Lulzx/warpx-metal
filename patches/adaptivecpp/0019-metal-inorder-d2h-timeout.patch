+void metal_inorder_queue::remember_submitted_command_buffer(
+    MTL::CommandBuffer* command_buffer) {
+  command_buffer->retain();
+  std::lock_guard<std::mutex> lock{_last_submitted_command_buffer_mutex};
+  if (_last_submitted_command_buffer) {
+    _last_submitted_command_buffer->release();
+  }
+  _last_submitted_command_buffer = command_buffer;
+}
+
+result metal_inorder_queue::wait_for_last_submitted_command_buffer(
+    const char* operation) {
+  MTL::CommandBuffer* command_buffer = nullptr;
+  {
+    std::lock_guard<std::mutex> lock{_last_submitted_command_buffer_mutex};
+    command_buffer = std::exchange(_last_submitted_command_buffer, nullptr);
+  }
+  if (!command_buffer) {
+    return make_success();
+  }
+
+  auto completion = wait_for_metal_command_buffer(command_buffer, operation);
+  command_buffer->release();
+  return completion;
+}
