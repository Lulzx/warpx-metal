# Langmuir 2D wave test — physics validation
# Outputs field energy every step to verify oscillation at plasma frequency
# n0 = 2e24 m^-3, expected wp = sqrt(2*n0*q_e^2/(eps0*m_e)) ~ 1.127e14 rad/s
# Period Tp = 2*pi/wp ~ 5.57e-14 s, dt ~ 2.948e-15 s => ~18.9 steps/period
max_step = 80

amr.n_cell = 128 128
amr.max_grid_size = 64
amr.max_level = 0

geometry.dims = 2
geometry.prob_lo = -20.e-6 -20.e-6
geometry.prob_hi =  20.e-6  20.e-6

boundary.field_lo = periodic periodic
boundary.field_hi = periodic periodic

warpx.verbose = 1
warpx.cfl = 1.0
warpx.use_filter = 0

algo.field_gathering = energy-conserving
algo.current_deposition = direct
algo.particle_shape = 1

particles.species_names = electrons positrons

electrons.charge = -q_e
electrons.mass = m_e
electrons.injection_style = "NUniformPerCell"
electrons.num_particles_per_cell_each_dim = 2 2
electrons.xmin = -20.e-6
electrons.xmax =  20.e-6
electrons.zmin = -20.e-6
electrons.zmax =  20.e-6
electrons.profile = constant
electrons.density = 2.e24
electrons.momentum_distribution_type = constant
electrons.ux = 0.01
electrons.uy = 0.0
electrons.uz = 0.01

positrons.charge = q_e
positrons.mass = m_e
positrons.injection_style = "NUniformPerCell"
positrons.num_particles_per_cell_each_dim = 2 2
positrons.xmin = -20.e-6
positrons.xmax =  20.e-6
positrons.zmin = -20.e-6
positrons.zmax =  20.e-6
positrons.profile = constant
positrons.density = 2.e24
positrons.momentum_distribution_type = constant
positrons.ux = -0.01
positrons.uy = 0.0
positrons.uz = -0.01

# Reduced diagnostics - output field and kinetic energy every step
warpx.reduced_diags_names = FieldEnergy ParticleEnergy

FieldEnergy.type = FieldEnergy
FieldEnergy.intervals = 1

ParticleEnergy.type = ParticleEnergy
ParticleEnergy.intervals = 1

diagnostics.diags_names = diag1
diag1.intervals = 99999
diag1.diag_type = Full
